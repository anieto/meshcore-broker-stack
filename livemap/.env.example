# Copy to .env and fill in values before deploying.
# .env is gitignored — never commit it.

# --- MQTT source ---
# Connects to the `broker` service directly over the internal Docker
# network (same compose stack) instead of routing out through
# Cloudflare and back — same broker CoreScope uses, just a shorter path.
# TLS is terminated at the Cloudflare Tunnel edge, not the broker
# container itself, so this internal hop is plain (unencrypted) WS.
MQTT_HOST=broker
MQTT_PORT=8883
MQTT_TRANSPORT=websockets
MQTT_WS_PATH=/
MQTT_TLS=false
MQTT_TOPIC=meshcore/#

# Dedicated read-only subscriber account — add a matching SUBSCRIBER_N
# line (role 2, full_access) to broker/.env on the VPS first. Don't
# reuse CoreScope's "corescope" subscriber account for this.
MQTT_USERNAME=livemap
MQTT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Site metadata ---
SITE_TITLE=MeshTexas Live Map
SITE_DESCRIPTION=Live view of MeshTexas MeshCore nodes, message routes, and advert paths across Texas.
SITE_URL=https://livemap.meshtexas.net
SITE_OG_IMAGE=https://meshtexas.net/logo-wide.png
SITE_FEED_NOTE=Feed: MeshTexas MQTT broker.

# Links node/route detail popups in the UI back into CoreScope
# (#/packets/<hash>, #/nodes/<pubkey>) instead of the legacy
# PACKET_ANALYZER_URL option.
CORESCOPE_URL=https://analyzer.meshtexas.net

# --- Map defaults ---
# Austin-centered, matches corescope/config.json's mapDefaults.center.
MAP_START_LAT=30.2672
MAP_START_LON=-97.7431
MAP_START_ZOOM=8
DISTANCE_UNITS=mi
NODE_MARKER_RADIUS=8

# --- Server ---
WEB_PORT=8080
PROD_MODE=false
STATE_DIR=/data
BACKUP_ENABLED=true
BACKUP_DIR=/backup
BACKUP_RETENTION_DAYS=7

# Everything else (route/heat TTLs, LOS tuning, weather, Turnstile,
# coverage layer, etc.) stays at the upstream image's defaults — see
# the live-map repo's README/howto.md for the full var list if any of
# those need tuning later.
