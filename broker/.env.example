# Copy to .env and fill in values before deploying.
# .env is gitignored — never commit it.

# MQTT broker listen settings (internal only — Cloudflare Tunnel accesses this)
MQTT_WS_PORT=8883
MQTT_HOST=0.0.0.0

# Must match the subdomain you configure in the Cloudflare Tunnel route.
# Devices mint JWT tokens with this as the "aud" claim — if it doesn't match,
# auth fails and devices are rejected.
AUTH_EXPECTED_AUDIENCE=mqtt.meshtexas.net

# Comma-separated list of region codes allowed to publish — this is what
# keeps the broker scoped to your region instead of becoming an open relay
# for anyone worldwide. Codes are whatever short tags your devices use to
# identify themselves (MeshTexas uses IATA airport codes, e.g. SAT for San
# Antonio). Leave empty/unset to accept publishers from any region.
ALLOWED_REGIONS=SAT,AUS,HOU

# Subscriber accounts (read-only — CoreScope and future tools use these).
# Format: username:password:role:maxConnections
#   Role 1 = admin (full data including PII internal topics)
#   Role 2 = full_access (SNR/RSSI intact, no PII)
#   Role 3 = limited (SNR/RSSI stripped)
# CoreScope needs Role 2 to show signal strength on the map.
SUBSCRIBER_MAX_CONNECTIONS_DEFAULT=2
SUBSCRIBER_1=corescope:CHANGE_ME_STRONG_PASSWORD:2
SUBSCRIBER_2=admin:CHANGE_ME_ADMIN_PASSWORD:1

# Abuse detection (leave defaults for now, tune if operators misbehave)
ABUSE_ENFORCEMENT_ENABLED=false
ABUSE_DUPLICATE_WINDOW_SIZE=100
ABUSE_DUPLICATE_WINDOW_MS=300000
ABUSE_DUPLICATE_THRESHOLD=10
ABUSE_MAX_DUPLICATES_PER_PACKET=5
ABUSE_DUPLICATE_RATE_THRESHOLD=0.3
ABUSE_DUPLICATE_RATE_WINDOW_MS=300000
ABUSE_BUCKET_CAPACITY=20
ABUSE_BUCKET_REFILL_RATE=3
ABUSE_MAX_PACKET_SIZE=255
ABUSE_MAX_TOPICS_PER_DAY=3
ABUSE_ANOMALY_THRESHOLD=10
ABUSE_MAX_IATA_CHANGES_24H=3
ABUSE_TOPIC_HISTORY_SIZE=50
ABUSE_TOPIC_HISTORY_WINDOW_MS=86400000
ABUSE_PERSISTENCE_PATH=/data/abuse-detection.db
ABUSE_PERSISTENCE_INTERVAL_MS=300000
