# Copy to .env and fill in NTFY_TOKEN before deploying.
# .env is gitignored — never commit it.

# ntfy push (used by backup-and-update.sh). NTFY_URL can point at the public
# https://ntfy.sh or a self-hosted ntfy server. Topic is just a name; the
# token authorizes publishing. Leave NTFY_TOKEN blank to disable notifications.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=meshcore-alerts
NTFY_TOKEN=
